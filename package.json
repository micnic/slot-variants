{
	"name": "slot-variants",
	"version": "1.2.0",
	"description": "Type-safe class name variants with slots",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./eslint-plugin": {
			"types": "./dist/eslint-plugin.d.ts",
			"import": "./dist/eslint-plugin.js",
			"require": "./dist/eslint-plugin.cjs"
		}
	},
	"sideEffects": false,
	"files": [
		"AGENTS.md",
		"dist",
		"logo.svg"
	],
	"scripts": {
		"build": "tsup src/index.ts src/eslint-plugin.ts && rm dist/index.d.cts dist/eslint-plugin.d.cts",
		"test": "tap --show-full-coverage test/*.test.ts",
		"bench": "jiti bench/cn.ts && jiti bench/cva.ts && jiti bench/tv.ts",
		"lint": "eslint src",
		"format": "prettier --write src",
		"format:check": "prettier --check src",
		"prepublishOnly": "npm run build"
	},
	"repository": "github:micnic/slot-variants",
	"keywords": [
		"classes",
		"classname",
		"classnames",
		"variants",
		"slots"
	],
	"author": "Nicu Micleușanu",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@stylistic/eslint-plugin": "^5.10.0",
		"class-variance-authority": "^0.7.1",
		"classnames": "^2.5.1",
		"eslint": "^10.2.1",
		"jiti": "2.6.1",
		"oxlint": "1.61.0",
		"prettier": "3.8.1",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tap": "21.5.0",
		"tinybench": "^6.0.0",
		"tsup": "8.5.1",
		"typescript": "5.9.3",
		"typescript-eslint": "^8.59.0"
	},
	"tsup": {
		"dts": true,
		"format": [
			"cjs",
			"esm"
		]
	}
}
